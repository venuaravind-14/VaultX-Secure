{
  "name": "vaultx-backend",
  "version": "1.0.0",
  "description": "Production-grade secure file vault backend - VaultX Secure",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit"
  },
  "keywords": [
    "vault",
    "security",
    "encryption",
    "nodejs",
    "express"
  ],
  "author": "VaultX Team",
  "license": "MIT",
  "dependencies": {
    "argon2": "^0.31.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.1",
    "express-slow-down": "^2.1.0",
    "express-validator": "^7.3.2",
    "file-type": "^16.5.4",
    "gridfs-stream": "^1.1.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.23.0",
    "multer": "^1.4.5-lts.1",
    "multer-gridfs-storage": "^5.0.2",
    "nodemailer": "^6.9.13",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "qrcode": "^1.5.4",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "winston-mongodb": "^5.1.1",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "overrides": {
    "multer-gridfs-storage": {
      "multer": "$multer"
    }
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "setupFilesAfterFramework": []
  }
}
