# =============================================================================
# VaultX Secure — Environment Variables
# Copy this to .env and fill in your values. Never commit .env to Git!
# =============================================================================

# --- Server ---
PORT=5000
NODE_ENV=development          # development | production

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017/vaultx_secure

# --- JWT Secrets (generate with: node -e "require('crypto').randomBytes(64).toString('hex')" ) ---
JWT_ACCESS_SECRET=CHANGE_ME_generate_a_64_byte_hex_string_for_access_token
JWT_REFRESH_SECRET=CHANGE_ME_generate_a_64_byte_hex_string_for_refresh_token
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- QR Code JWT (separate secret, separate rotation schedule) ---
QR_SECRET=CHANGE_ME_generate_a_64_byte_hex_string_for_qr_codes

# --- File Encryption Master Key ---
# Used for wrapping File Encryption Keys (FEKs) via AES-256-GCM.
# MUST be exactly 32 bytes (64 hex chars).
# Generate: node -e "require('crypto').randomBytes(32).toString('hex')"
ENCRYPTION_MASTER_KEY=CHANGE_ME_64_hex_char_string_exactly_32_bytes

# --- Google OAuth 2.0 ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# --- Frontend (CORS whitelist) ---
FRONTEND_URL=http://localhost:3000

# --- File Upload ---
MAX_FILE_SIZE_MB=50           # Maximum upload size in megabytes

# --- Argon2id Parameters ---
ARGON2_MEMORY_COST=65536      # 64 MiB (in KiB)
ARGON2_TIME_COST=3            # Number of iterations
ARGON2_PARALLELISM=4          # Degree of parallelism

# --- PBKDF2 (for Master Key derivation) ---
PBKDF2_ITERATIONS=600000      # OWASP 2024 recommendation for SHA-512
PBKDF2_KEYLEN=32              # Output key length in bytes (256 bits)
PBKDF2_DIGEST=sha512

# --- HMAC Salt for Share Links ---
# Generate: node -e "require('crypto').randomBytes(32).toString('hex')"
SHARE_LINK_HMAC_SECRET=CHANGE_ME_64_hex_char_string_for_share_link_hmac

# --- Email (SMTP) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false            # true for 465, false for other ports
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password  # Use an App Password, NOT your account password
EMAIL_FROM="VaultX Secure <noreply@vaultx.io>"

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes in milliseconds
RATE_LIMIT_MAX=100            # Max requests per window per IP (global)
AUTH_RATE_LIMIT_MAX=10        # Max requests per window per IP (auth routes)
SHARE_RATE_LIMIT_MAX=20       # Max requests per window per IP (share access)
